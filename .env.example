# =============================================================================
# Litwill Garden - Environment Variables
# =============================================================================
# Copy this file to .env (or .env.local) and fill in your values.
# NEVER commit .env / .env.local to git.

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/litwill_garden

# AI (Claude API)
ANTHROPIC_API_KEY=sk-ant-...

# Stripe (決済)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (メール送信)
RESEND_API_KEY=re_...
OWNER_EMAIL=owner@example.com

# Site
NEXT_PUBLIC_BASE_URL=https://www.litwillgarden.com

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# SNS APIs
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
YOUTUBE_API_KEY=
TIKTOK_ACCESS_TOKEN=

# note.com
NOTE_API_TOKEN=

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
GA4_PROPERTY_ID=
SEARCH_CONSOLE_SITE_URL=https://www.litwillgarden.com

# AdSense（広告収益）
# パブリッシャーID。設定すると AdSense タグ・ads.txt・記事内広告が有効化される
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# 記事内に表示する広告ユニットのスロットID
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE=

# Notifications
SLACK_WEBHOOK_URL=

# Cron authentication
CRON_SECRET=
